generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model StoreSubscription {
  id            Int      @id @default(autoincrement())
  shop          String   @unique
  plan          String   @default("free")
  billingStatus String   @default("active")
  email         String?
  ownerName     String?
  shopName      String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model TemplateUsage {
  id         Int      @id @default(autoincrement())
  shop       String
  templateId String
  usedAt     DateTime @default(now())
}

model SelectedTemplate {
  id           Int      @id @default(autoincrement())
  shop         String   @unique
  templateId   String
  templateName String
  configData   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PublishedForm {
  id           String   @id @default(uuid())
  shop         String
  templateId   String
  templateName String
  configData   String?
  pageId       String?
  pageUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
